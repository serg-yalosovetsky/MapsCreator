<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Android 11+: без этого блока bindService к net.osmand возвращает false -->
    <queries>
        <package android:name="net.osmand" />
        <package android:name="net.osmand.plus" />
    </queries>

    <application
        android:label="MapsCreator for OsmAnd"
        android:icon="@android:drawable/ic_menu_mapmode">

        <!--
            OsmAnd сканирует установленные APK с этим meta-data и показывает их
            в Settings → Plugins. android:value="true" — формат OsmAnd 4.x.
        -->
        <meta-data
            android:name="osmand.plugin"
            android:value="true" />

        <!--
            OsmAnd запускает эту Activity когда пользователь нажимает «Settings»
            рядом с плагином в списке. Theme.NoDisplay завершает Activity сразу
            (без UI), стартуя OsmAndButtonService.
        -->
        <activity
            android:name=".PluginActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="net.osmand.api.PLUGIN" />
            </intent-filter>
            <!-- OsmAnd fires this URI when user taps nav drawer item -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="mapscreator" />
            </intent-filter>
        </activity>

        <!--
            Поддерживает AIDL-соединение с OsmAnd, регистрирует кнопку
            «Скачать в MapsCreator» в навигационной панели и обрабатывает клики.
            Запускается OsmAndAutoStartReceiver и PluginActivity.
        -->
        <service
            android:name=".OsmAndButtonService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        <!--
            Перезапускает OsmAndButtonService при старте устройства и при
            запуске OsmAnd (net.osmand.api.OSMAND_STARTED).
        -->
        <receiver
            android:name=".OsmAndAutoStartReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="net.osmand.api.OSMAND_STARTED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
